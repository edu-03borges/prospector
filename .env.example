# Variáveis de ambiente para o Prospector iMotio
# Copie este arquivo para .env e preencha com suas credenciais

# ── Groq (geração de mensagens com IA — gratuito) ────────────────────────────
# Crie conta em https://console.groq.com/keys (plano gratuito generoso)
GROQ_API_KEY=

# ── Hunter.io (enriquecimento de e-mail — opcional) ───────────────────────────
# Plano gratuito: 25 buscas/mês. https://hunter.io/users/sign_up
HUNTER_API_KEY=

# ── Banco de dados ────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///data/prospector.db

# ── Configurações gerais ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
